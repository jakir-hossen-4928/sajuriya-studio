rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Apps Collection: Anyone can view, only admins can manage
    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Collection: Users manage their own profiles, but can't change their own roles
    match /users/{userId} {
      // Users can read their own profile, Admins can read all profiles
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow user creation if they are signing up as a standard 'user'
      allow create: if request.auth != null && 
                     request.auth.uid == userId && 
                     request.resource.data.role == 'user';
      
      // Allow updates to own profile, but prevent changing the role field
      allow update: if request.auth != null && 
                     request.auth.uid == userId && 
                     request.resource.data.role == resource.data.role;
      
      // Allow account deletion by the user
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}